rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId}
    // Fields: uid, email, displayName, photoURL, preferredModel
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields: id, userId, name, script, analysis, createdAt
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isProjectOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // Project Rules
    match /projects/{projectId} {
      allow read: if isProjectOwner();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isProjectOwner() && request.resource.data.userId == resource.data.userId;
      allow delete: if isProjectOwner();
    }
  }
}
