{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "preferredModel": { "type": "string", "enum": ["gemini-3-flash-preview", "gemini-2.0-pro-exp-02-05"] }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "Storyboard project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "script": { "type": "string" },
        "analysis": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name", "script"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Storyboard projects"
    }
  }
}
